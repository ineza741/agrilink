{
  "name": "agrisupport-backend",
  "version": "1.0.0",
  "description": "Phase 1 backend for AgriSupport AI - authentication, farmer profiles, farms, crop history, and admin approvals.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name phase1_init",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio",
    "validate": "prisma validate"
  },
  "keywords": [
    "agriculture",
    "express",
    "prisma",
    "jwt",
    "backend"
  ],
  "author": "Rodrigue / Codex",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.16.2",
    "supertest": "^7.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
